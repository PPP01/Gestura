{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "version": "2.3",
    "author": "PPP01 (based on FlowMouse by Hmily[LCG] & Coxxs)",
    "description": "__MSG_extDescription__",
    "default_locale": "en",
    "minimum_chrome_version": "109",
    "browser_specific_settings": {
        "gecko": {
            "id": "gestura@gestura.eu",
            "strict_min_version": "140.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "tabs",
        "sessions",
        "storage",
        "contextMenus",
        "search",
        "scripting"
    ],
    "optional_permissions": [
        "bookmarks",
        "clipboardRead",
        "downloads"
    ],
    "options_ui": {
        "page": "pages/options.html",
        "open_in_tab": true
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "scripts": ["js/menu-patterns.js", "js/menu-catalog.js", "js/menu-model.js", "js/favicon-util.js", "js/background.js"]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "js/constants.js",
                "js/gesture-visual.js",
                "js/gesture-recognizer.js",
                "js/search-url.js",
                "js/search-engines-catalog.js",
                "js/engine-registry.js",
                "js/favicon-util.js",
                "js/menu-catalog.js",
                "js/menu-model.js",
                "js/content.js"
            ],
            "run_at": "document_start",
            "all_frames": true,
            "match_origin_as_fallback": true
        }
    ],
    "action": {
        "default_popup": "pages/popup.html",
        "default_icon": {
            "16": "icons/icon16-tile.png",
            "32": "icons/icon32-tile.png",
            "48": "icons/icon48-tile.png",
            "128": "icons/icon128-tile.png"
        }
    },
    "icons": {
        "16": "icons/icon16-tile.png",
        "32": "icons/icon32-tile.png",
        "48": "icons/icon48-tile.png",
        "128": "icons/icon128-tile.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "_locales/*/messages.json",
                "pages/context-menu.html"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}